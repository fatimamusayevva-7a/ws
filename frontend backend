@app.route("/api/login", methods=["POST"])
def api_login():
    data     = request.get_json(force=True) or {}
    email    = str(data.get("email",    "")).strip()
    password = str(data.get("password", "")).strip()

    if not email or not password:
        return jsonify({"ok": False, "error": "Email və parol tələb olunur."}), 400

    # ── Lab: SQLi zəifliyi ──────────────────────────────────
    if DEV_INSECURE_SQL:
        try:
            row = _user_lookup_concat(email)   # ← ZƏİF funksiya
        except Exception as e:
            # Verilənlər bazası xətasını clientə göstər (lab effekti)
            return jsonify({
                "ok": False,
                "error": "db_error",
                "db_message": str(e),
                "sql_fragment": email[:280]
            }), 200
    else:
        row = _user_lookup_safe(email)         # ← TƏHLÜKƏSİZ funksiya

    if row is None:
        return jsonify({"ok": False, "error": "İstifadəçi tapılmadı."}), 401

    # ── Lab: Parol yoxlamasının keçilməsi ───────────────────
    if DEV_INSECURE_SQL and DEV_AUTH_BYPASS:
        pw_ok = True   # ← LAB: parol yoxlanılmır!
    else:
        from werkzeug.security import check_password_hash
        pw_ok = check_password_hash(row["password_hash"], password)

    if not pw_ok:
        return jsonify({"ok": False, "error": "Parol yanlışdır."}), 401

    # Sessiya yaz
    db_user = user_get_by_id(row["id"])

    # UNION ilə saxta id gəldisə — sessiya yaratma, sadəcə məlumatı göstər (lab)
    if db_user is None:
        probe: Dict[str, Any] = {}
        for k in row.keys():
            v = row[k]
            probe[k] = v.isoformat() if hasattr(v, "isoformat") else v
        return jsonify({
            "ok": True,
            "query_probe": True,
            "session_created": False,
            "user": probe,
            "sql_fragment": email[:280]
        })

    session["user_id"] = db_user["id"]
    session["email"]   = db_user["email"]
    session["role"]    = db_user["role"]

    return jsonify({
        "ok": True,
        "message": "Giriş uğurlu!",
        "user": {
            "id":        db_user["id"],
            "email":     db_user["email"],
            "full_name": db_user["full_name"],
            "role":      db_user["role"]
        }
    })


