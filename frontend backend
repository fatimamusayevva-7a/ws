@app.route("/api/orders/<int:oid>", methods=["GET"])
def api_order_by_id(oid: int):
    """
    Tək sifariş.

    IDOR ZƏİFLİYİ (lab):
      user_id yoxlanılmır → hər kəs /api/orders/1, /api/orders/2 ... ilə
      başqasının sifarişini görə bilər.

    TƏHLÜKƏSİZ versiya: WHERE id = %s AND user_id = %s
    """
    if "user_id" not in session:
        return jsonify({"ok": False, "error": "Daxil olun."}), 401

    conn = get_db(); cur = conn.cursor()

    if DEV_INSECURE_SQL:
        # ── ZƏİF: IDOR — user_id yoxlanılmır ───────────────
        cur.execute("SELECT * FROM orders WHERE id = %s", (oid,))
    else:
        # ── TƏHLÜKƏSİZ: yalnız öz sifarişi ─────────────────
        cur.execute(
            "SELECT * FROM orders WHERE id = %s AND user_id = %s",
            (oid, session["user_id"])
        )

    row = cur.fetchone()
    conn.close()

    if not row:
        return jsonify({"ok": False, "error": "Sifariş tapılmadı."}), 404

    return jsonify({"ok": True, "order": dict(row)})


