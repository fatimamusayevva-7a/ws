def user_get_by_id(user_id: int) -> Optional[Dict]:
    """İD ilə istifadəçini tapır (parametrləşdirilmiş — TƏHLÜKƏSİZ)."""
    conn = get_db(); cur = conn.cursor()
    cur.execute("SELECT id, email, full_name, role FROM users WHERE id = %s", (user_id,))
    row = cur.fetchone()
    conn.close()
    return dict(row) if row else None


# ─── TƏHLÜKƏSİZ: Parametrləşdirilmiş sorğu ─────────────────
def _user_lookup_safe(email: str) -> Optional[Dict]:
    """Giriş üçün istifadəçi axtarışı — TƏHLÜKƏSİZ versiya."""
    conn = get_db(); cur = conn.cursor()
    cur.execute(
        "SELECT id, email, password_hash, full_name, role FROM users WHERE email = %s",
        (email,)
    )
    row = cur.fetchone()
    conn.close()
    return dict(row) if row else None


# ─── ZƏİF (LAB): String birləşdirməsi → SQL İnjection ───────
def _user_lookup_concat(email: str) -> Optional[Dict]:
    """
    LAB — DEV_INSECURE_SQL aktiv olanda istifadə olunur.
    İstifadəçi girişi birbaşa SQL mətninə birləşdirilir!

    Hücum nümunəsi (email sahəsinə yazın):
      ' OR '1'='1
      admin@vivaladiva.com'--
      ' UNION SELECT 1,email,password_hash,full_name,'admin' FROM users--
    """
    conn = get_db(); cur = conn.cursor()
    sql = (
        "SELECT id, email, password_hash, full_name, role FROM users WHERE email = '"
        + email   # ← TƏHLÜKƏLİ: birbaşa birləşdirmə!
        + "'"
    )
    print(f"[LAB-SQLi] İcra olunan sorğu: {sql}")  # log üçün
    try:
        cur.execute(sql)
        row = cur.fetchone()
    except Exception as e:
        conn.close()
        raise e
    conn.close()
    return dict(row) if row else None


