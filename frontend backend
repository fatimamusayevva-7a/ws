# ── Mühit dəyişənləri ───────────────────────────────────────
DATABASE_URL = os.environ.get("DATABASE_URL", "")

def _env_flag(*names: str) -> bool:
    for n in names:
        v = os.environ.get(n, "").strip().lower()
        if v in ("1", "true", "yes"):
            return True
    return False

# Lab bayraqları
WEBSEC_LAB        = _env_flag("WEBSEC_LAB") or True          # default aktiv
DEV_INSECURE_SQL  = _env_flag("DEV_INSECURE_SQL")  or WEBSEC_LAB
DEV_AUTH_BYPASS   = _env_flag("DEV_AUTH_BYPASS")   or WEBSEC_LAB


