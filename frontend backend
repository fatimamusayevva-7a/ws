@app.route("/api/products", methods=["GET"])
def api_products():
    """
    Menyu məhsulları — axtarış parametri ilə.

    TƏHLÜKƏSİZ: GET /api/products
    LAB SQLi:    GET /api/products?search=' OR '1'='1
    """
    search = request.args.get("search", "").strip()
    conn = get_db(); cur = conn.cursor()

    if search and DEV_INSECURE_SQL:
        # ── ZƏİF: string birləşdirməsi ──────────────────────
        sql = "SELECT * FROM products WHERE name ILIKE '%" + search + "%'"
        print(f"[LAB-SQLi] Məhsul axtarışı: {sql}")
        try:
            cur.execute(sql)
        except Exception as e:
            conn.close()
            return jsonify({"ok": False, "error": str(e), "sql_fragment": search}), 200
    elif search:
        # ── TƏHLÜKƏSİZ: parametrləşdirilmiş ────────────────
        cur.execute("SELECT * FROM products WHERE name ILIKE %s", (f"%{search}%",))
    else:
        cur.execute("SELECT * FROM products ORDER BY id")

    rows = [dict(r) for r in cur.fetchall()]
    conn.close()
    return jsonify({"ok": True, "products": rows})


