@app.route("/api/admin/orders", methods=["GET"])
def api_admin_orders():
    """
    Admin paneli — bütün sifarişlər.

    ZƏİF: Yalnız email ilə yoxlanılır (RBAC yoxdur).
    Hücum: Əgər hər hansı istifadəçi admin@vivaladiva.com emaili ilə
           qeydiyyatdan keçə bilsəydi — admin panel açılardı.
    """
    if "user_id" not in session:
        return jsonify({"ok": False, "error": "Daxil olun."}), 401

    # ── ZƏİF admin yoxlaması (yoldaşının kodunda da eynidir) ─
    if session.get("email") != "admin@vivaladiva.com":
        return jsonify({"ok": False, "error": "Admin hüququnuz yoxdur."}), 403

    conn = get_db(); cur = conn.cursor()
    cur.execute("""
        SELECT o.id, o.product_name, o.quantity, o.total, o.status,
               o.created_at, u.email AS user_email, u.full_name
        FROM orders o
        JOIN users u ON u.id = o.user_id
        ORDER BY o.created_at DESC
    """)
    rows = [dict(r) for r in cur.fetchall()]
    conn.close()

    return jsonify({"ok": True, "orders": rows, "count": len(rows)})


