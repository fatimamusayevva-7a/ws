@app.route("/api/orders", methods=["POST"])
def api_place_order():
    """Yeni sifariş yarat."""
    if "user_id" not in session:
        return jsonify({"ok": False, "error": "Daxil olun."}), 401

    data         = request.get_json(force=True) or {}
    product_name = str(data.get("product_name", "")).strip()
    quantity     = int(data.get("quantity", 1))

    if not product_name:
        return jsonify({"ok": False, "error": "Məhsul adı tələb olunur."}), 400

    # Qiyməti tap
    conn = get_db(); cur = conn.cursor()
    cur.execute("SELECT price FROM products WHERE name = %s", (product_name,))
    prod = cur.fetchone()
    total = float(prod["price"]) * quantity if prod else 0.0

    cur.execute(
        "INSERT INTO orders (user_id, product_name, quantity, total) VALUES (%s, %s, %s, %s) RETURNING id",
        (session["user_id"], product_name, quantity, total)
    )
    order_id = cur.fetchone()["id"]
    conn.commit(); conn.close()

    return jsonify({"ok": True, "order_id": order_id, "total": total})


