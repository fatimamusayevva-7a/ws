@app.route("/", defaults={"path": "index.html"})
@app.route("/<path:path>")
def serve_file(path):
    if path.startswith("api/"):
        return "Tapılmadı", 404

    allowed = {".html", ".css", ".js", ".jpg", ".jpeg", ".png", ".ico", ".svg"}
    safe = (FRONTEND_DIR / path).resolve()

    # Path traversal mühafizəsi
    try:
        safe.relative_to(FRONTEND_DIR.resolve())
    except ValueError:
        return "Forbidden", 403

    if not safe.is_file():
        return "Tapılmadı", 404

    if safe.suffix.lower() not in allowed:
        return "Forbidden", 403

    return send_from_directory(FRONTEND_DIR, path)


